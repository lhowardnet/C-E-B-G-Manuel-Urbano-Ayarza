---
import LayoutBlog from "../../layouts/LayoutBlog.astro";
import BlogFeed from "../../components/blog/BlogFeed";
---

<LayoutBlog title="Blog" subtitle="C.E.B.G Manuel Urbano Ayarza">
    <div class="text-left mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-primary mb-4">
            Bienvenidos a nuestro Blog
        </h1>
        <p class="text-gray-600">
            Descubre las últimas noticias, eventos y logros de nuestra escuela.
        </p>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
        <div class="flex-1 w-full">
            <BlogFeed client:load />
        </div>

        <aside class="w-full md:w-80 flex flex-col gap-6">
            <div class="bg-white shadow-sm rounded-xl">
                <h3
                    class="font-bold text-2xl text-white bg-primary rounded-t-xl mb-4 p-4"
                >
                    Categorías
                </h3>
                <div class="p-4">
                    <ul class="space-y-2">
                        <li>
                            <span
                                class="block px-4 py-2 bg-secondary text-primary font-bold rounded-full text-lg"
                                >Todos</span
                            >
                        </li>
                        <li>
                            <span
                                class="block px-4 py-2 bg-primary/25 text-primary font-bold rounded-full text-lg"
                                >Robótica y Tecnología</span
                            >
                        </li>
                        <li>
                            <span
                                class="block px-4 py-2 bg-primary/25 text-primary font-bold rounded-full text-lg"
                                >Eventos Escolares</span
                            >
                        </li>
                        <li>
                            <span
                                class="block px-4 py-2 bg-primary/25 text-primary font-bold rounded-full text-lg"
                                >Vida Estudiantil</span
                            >
                        </li>
                    </ul>
                </div>
            </div>

            <div class="bg-white shadow-sm rounded-xl">
                <h3
                    class="font-bold text-2xl text-white bg-primary rounded-t-xl mb-4 p-4"
                >
                    Enlaces Rápidos
                </h3>
                <div class="p-4">
                    <ul class="space-y-2">
                        <li>
                            <a
                                href="/about"
                                class="text-primary text-lg transition-colors"
                                >› Acerca de</a
                            >
                        </li>
                        <li>
                            <a
                                href="#"
                                class="text-primary text-lg transition-colors"
                                >› Oferta Académica</a
                            >
                        </li>
                        <li>
                            <a
                                href="#"
                                class="text-primary text-lg transition-colors"
                                >› Contáctanos</a
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </aside>
    </div>
</LayoutBlog>
