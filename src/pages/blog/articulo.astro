---
import LayoutBlog from "../../layouts/LayoutBlog.astro";
import BlogArticleDetail from "../../components/blog/BlogArticleDetail";
import BlogSuggestedLinks from "../../components/blog/BlogSuggestedLinks";
---

<LayoutBlog title="Artículo" subtitle="Blog" description="Detalle de artículo del blog">
    <div class="grid grid-cols-1 lg:grid-cols-[75%_1fr] gap-8">
        <BlogArticleDetail client:load />

        <aside class="w-full md:w-80 lg:w-auto flex flex-col gap-6">
                <div class="py-4">
                    <a
                        href="/blog"
                        class="block w-full rounded-lg bg-primary px-4 py-3 text-center text-lg font-bold text-white transition-colors hover:bg-primary/90"
                    >
                        ← Volver al feed
                    </a>
                </div>

            <div class="bg-white shadow-sm rounded-xl">
                <h3
                    class="font-bold text-2xl text-white bg-primary rounded-t-xl mb-4 p-4"
                >
                    Enlaces Sugeridos
                </h3>
                <div class="p-4">
                    <BlogSuggestedLinks client:load />
                </div>
            </div>
        </aside>
    </div>
</LayoutBlog>
